DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobscheduler?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# worker tuning (all optional, sensible defaults in code)
POLL_INTERVAL_MS=1000
SWEEP_INTERVAL_MS=3000
HEARTBEAT_INTERVAL_MS=5000
MAX_CLAIM_PER_QUEUE_PER_TICK=5
SHUTDOWN_GRACE_MS=15000
